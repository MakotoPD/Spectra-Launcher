{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Spectra Launcher",
  "version": "0.4.1",
  "identifier": "pl.makoto.spectra-launcher",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run generate"
  },
  "app": {
    "windows": [
      {
        "title": "Spectra Launcher",
        "width": 1370,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1100,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DATA/SpectraLauncher/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MakotoPD/Spectra-Launcher/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5RTUyRTU4MkQ4NEI3MjgKUldRb3Q0UXRXQzdsaVZMYXRXUDl3ZktqcmhYUy9wck15dDBvd0xobk5TenhaN0QxYlpsTk5LU2QK",
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
