{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mako Launcher",
  "version": "0.1.0",
  "identifier": "pl.makoto.mako-launcher",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run generate"
  },
  "app": {
    "windows": [
      {
        "title": "Mako Launcher",
        "width": 1370,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1100,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DATA/MakoLauncher/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
