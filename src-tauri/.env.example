# Launcher build-time secrets — copy to src-tauri/.env (injected via build.rs).
DISCORD_CLIENT_ID=

CURSEFORGE_API_KEY=

# Note: telemetry is NOT configured here. The endpoint + optional ingest key are
# constants in app/composables/useTelemetry.ts (TELEMETRY_ENDPOINT, INGEST_KEY),
# and the server-side vars (ADMIN_TOKEN, SPECTRA_INGEST_KEY, TELEMETRY_DB_PATH)
# live in the Spectra-Web repo's .env.example.
